# Server
PORT=8080
NODE_ENV=development
TIME_ZONE=Asia/Taipei
APP_BASE_URL=http://localhost:8080

# Dashboard auth
DASHBOARD_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string
DASHBOARD_SESSION_DAYS=30

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# Keep true only for local payload testing. Set false in Cloud Run.
ALLOW_UNSIGNED_WEBHOOKS=true

# Google Sheets / Drive
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Records
GOOGLE_GROUPS_SHEET_NAME=Groups
GOOGLE_DRIVE_FOLDER_ID=
# Use either GOOGLE_SERVICE_ACCOUNT_JSON or GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
USER_HASH_SALT=replace-with-a-private-salt

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_GOOGLE_SEARCH_ENABLED=true
GEMINI_TEXT_ANALYSIS_ENABLED=true
GEMINI_DAILY_LIMIT=50
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDERS=openrouter,nvidia
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_WEB_SEARCH_ENABLED=true
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
LINE_BOT_QA_ENABLED=true
LINE_BOT_QA_CONTEXT_LIMIT=30

# Dashboard/API limits
PUBLIC_RECENT_LIMIT=10
ADMIN_PAGE_SIZE=100
